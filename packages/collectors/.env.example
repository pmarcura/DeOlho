# Conexão Postgres (mesmo formato do packages/db/.env). Necessária para que os
# adapters gravem em raw_records / contracts / payments / gazettes / etc. Sem
# isso, os collectors degradam para apenas snapshot JSON em data/.
DATABASE_URL=postgres://deolho:deolho@localhost:5432/deolho

# Chave gratuita da API da CGU (CEIS/CNEP — sanções a empresas).
# Cadastrar e-mail em: https://portaldatransparencia.gov.br/api-de-dados/cadastrar-email
PORTAL_TRANSPARENCIA_API_KEY=

# Agente leve de apresentação dos eventos.
# local  = zero chamadas externas, determinístico e barato (padrão)
# ollama = LLM local via http://127.0.0.1:11434/api/generate
# openai = OpenAI Responses API
# auto   = tenta Ollama e cai para local sem consumir tokens externos
DEOLHO_POST_AGENT_PROVIDER=local
DEOLHO_POST_AGENT_LOCAL_MODEL=llama3.2:3b
OLLAMA_HOST=http://127.0.0.1:11434

# Só necessário quando DEOLHO_POST_AGENT_PROVIDER=openai.
OPENAI_API_KEY=
DEOLHO_POST_AGENT_MODEL=gpt-4.1-nano
