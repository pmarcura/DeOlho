# Conexão Postgres usada pelo driver `postgres` (porsager) e pelo drizzle-kit.
#
# Local (docker compose up -d na raiz):
#   postgres://deolho:deolho@localhost:5432/deolho
#
# Supabase / Neon: copie a connection string do painel (use a porta de sessão,
# não a de pooler transacional, para rodar migrations).
DATABASE_URL=postgres://deolho:deolho@localhost:5432/deolho
